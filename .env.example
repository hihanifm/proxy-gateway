# Copy to .env and adjust as needed. Never commit .env.

# Base image override — change to internal mirror if Docker Hub is blocked
# PYTHON_IMAGE=public.ecr.aws/docker/library/python:3.11-slim

# Proxy settings — set if your lab routes outbound traffic through a proxy
# HTTP_PROXY=http://proxy.internal:3128
# HTTPS_PROXY=http://proxy.internal:3128
# NO_PROXY=localhost,127.0.0.1,mock-backend,.internal


# Which adapter to use: "stub" (no network) or "internal" (real backend)
GATEWAY_ADAPTER=stub

# Base URL of your proprietary internal LLM backend
BACKEND_BASE_URL=http://localhost:8001

# Health check path on the backend
BACKEND_HEALTH_PATH=/health

# Seconds to wait for a backend response before timing out
BACKEND_TIMEOUT_S=30

# How often (seconds) to poll the backend health endpoint
HEALTH_CHECK_INTERVAL_S=15

# Port the gateway listens on
PORT=8000

# Comma-separated list of model names the gateway advertises
GATEWAY_MODELS=gpt-3.5-turbo,gpt-4

# Mock backend only: simulated response delay in milliseconds
MOCK_DELAY_MS=200

# OpenAI adapter — required when GATEWAY_ADAPTER=openai
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
